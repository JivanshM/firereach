# ══════════════════════════════════════════════
# ReachAI — EmailJS Configuration
# ══════════════════════════════════════════════
# Create a copy of this file named .env in
# the frontend/ directory and fill in your
# EmailJS credentials from https://emailjs.com
#
# Your EmailJS template must have these
# variables: {{to_email}}, {{subject}}, {{body}}
# ══════════════════════════════════════════════

VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key
