# FireReach - Required API Keys
# Copy this to .env and fill in your keys

# --- LLM (you need at least ONE) ---

# PRIMARY LLM: GPT-4o via AIML API
# Signup: https://aimlapi.com/
AIML_API_KEY=
AIML_BASE_URL=https://api.aimlapi.com/v1
AIML_MODEL=gpt-4o

# FALLBACK LLM: Google Gemini 2.0 Flash (free tier)
# Signup: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- Signal Harvester APIs ---

# Finnhub: Financial data, company profiles, stock news
# Signup: https://finnhub.io/register (Free: 60 API calls/minute)
FINNHUB_API_KEY=

# GNews: Latest news articles about target companies
# Signup: https://gnews.io/ (Free: 100 requests/day)
GNEWS_API_KEY=

# --- Email Sending ---

# Brevo (formerly Sendinblue): Automated email dispatch
# Signup: https://app.brevo.com/account/register (Free: 300 emails/day)
# Get key: Settings > SMTP & API > API Keys
BREVO_API_KEY=

# Sender email (must be verified in Brevo — they email you a confirmation link)
SENDER_EMAIL=

# --- App Config ---

FRONTEND_URL=http://localhost:5173
