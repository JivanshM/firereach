# Google Gemini API Key (free tier: https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Finnhub API Key (free: 60 calls/min - https://finnhub.io/)
FINNHUB_API_KEY=your_finnhub_api_key_here

# GNews API Key (free: 100 requests/day - https://gnews.io/)
GNEWS_API_KEY=your_gnews_api_key_here

# Resend API Key (free: 100 emails/day - https://resend.com/)
RESEND_API_KEY=your_resend_api_key_here

# Sender email (use verified domain or Resend default)
SENDER_EMAIL=onboarding@resend.dev

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173
